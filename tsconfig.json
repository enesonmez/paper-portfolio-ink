{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "#db": ["./db/index.ts"],
      "~/*": ["./app/*"],
      "#db/*": ["./db/*"],
      "#root/*": ["./*"],
      "#workers/*": ["./workers/*"]
    },
    "types": [
      "node",
      "@cloudflare/workers-types",
      "vite/client",
      "vitest/globals",
      "vitest/jsdom"
    ]
  },
  "include": [
    "app",
    "db",
    "tests",
    "workers",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "react-router.config.ts"
  ]
}
