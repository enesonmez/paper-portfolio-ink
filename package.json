{
  "name": "paper-enes-ink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Edge-first personal portfolio and blog built with React Router v7 on Cloudflare.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "react-router build && wrangler dev",
    "deploy": "react-router build && wrangler deploy",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@react-router/cloudflare": "^7.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.9.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260303.0",
    "@react-router/dev": "^7.9.4",
    "@react-router/fs-routes": "^7.9.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.7",
    "wrangler": "^4.8.0"
  },
  "packageManager": "npm@10.9.2"
}
