{
  "name": "paper-enes-ink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Edge-first personal portfolio and blog built with React Router v7 on Cloudflare.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "react-router build && wrangler dev",
    "deploy": "react-router build && wrangler deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/vt323": "^5.2.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/cloudflare": "^7.9.4",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.9.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260303.0",
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "^7.9.4",
    "@react-router/fs-routes": "^7.9.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.7",
    "wrangler": "^4.8.0"
  },
  "packageManager": "npm@10.9.2"
}
